{
  "name": "ollama-auto-commit",
  "displayName": "ollama-auto-commit",
  "description": "uses local ollama model to auto generate commit messages for staged files",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ollamaActivityBar",
          "title": "Ollama Auto Commit",
          "icon": "resources/download.svg"
        }
      ]
    },
    "views": {
      "ollamaActivityBar": [
        {
          "id": "ollamaCommitView",
          "name": "Ollama Auto Commit"
        }
      ]
    },
    "commands": [
      {
        "command": "ollama-auto-commit.greet",
        "title": "Hello World"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}