{
  "name": "ollama-auto-commit",
  "displayName": "ollama-auto-commit",
  "description": "uses local ollama model to auto generate commit messages for staged files",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ollamaActivityBar",
          "title": "Ollama Auto Commit",
          "icon": "resources/download.svg"
        }
      ]
    },
    "views": {
      "ollamaActivityBar": [
        {
          "id": "ollamaCommitView",
          "name": "Ollama Auto Commit"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "ollama-auto-commit.pickModel",
          "when": "view == ollamaCommitView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "ollama-auto-commit.stage",
          "when": "viewItem == unstagedItem",
          "group": "inline"
        },
        {
          "command": "ollama-auto-commit.unstage",
          "when": "viewItem == stagedItem",
          "group": "inline"
        },
        {
          "command": "ollama-auto-commit.unstageAll",
          "when": "viewItem == stagedSection",
          "group": "inline"
        },
        {
          "command": "ollama-auto-commit.stageAll",
          "when": "viewItem == unstagedSection",
          "group": "inline"
        }
      ]
    },
    "commands": [
      {
        "command": "ollama-auto-commit.pickModel",
        "title": "Select model",
        "icon": "resources/model.svg"
      },
      {
        "command": "ollama-auto-commit.listModels",
        "title": "List Models"
      },
      {
        "command": "ollama-auto-commit.stageAll",
        "title": "Stage All files",
        "icon": "$(add)"
      },
      {
        "command": "ollama-auto-commit.unstageAll",
        "title": "Unstage All files",
        "icon": "$(discard)"
      },
      {
        "command": "ollama-auto-commit.stage",
        "title": "Stage file",
        "icon": "$(add)"
      },
      {
        "command": "ollama-auto-commit.unstage",
        "title": "Unstage file",
        "icon": "$(discard)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}